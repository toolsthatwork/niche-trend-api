{
  "openapi": "3.1.0",
  "info": {
    "title": "URL Tools and Redirect Tracer",
    "description": "Trace URL redirects and unshorten URLs, check HTTP status codes, parse URL components, and bulk-check up to 20 URLs. Identify redirect chains, final destinations, and server response times.",
    "version": "1.0.0"
  },
  "paths": {
    "/url/": {
      "get": {
        "tags": [
          "URL Tools"
        ],
        "summary": "API Info",
        "operationId": "url_info_url__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/url/trace": {
      "get": {
        "tags": [
          "URL Tools"
        ],
        "summary": "Trace redirects for a URL (unshorten)",
        "operationId": "trace_redirects_url_trace_get",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "URL to trace (e.g. a shortened URL)",
              "title": "Url"
            },
            "description": "URL to trace (e.g. a shortened URL)"
          },
          {
            "name": "max_redirects",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 20,
              "minimum": 1,
              "description": "Max redirects to follow",
              "default": 10,
              "title": "Max Redirects"
            },
            "description": "Max redirects to follow"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/url/status": {
      "get": {
        "tags": [
          "URL Tools"
        ],
        "summary": "Check HTTP status of a URL",
        "operationId": "check_status_url_status_get",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "URL to check",
              "title": "Url"
            },
            "description": "URL to check"
          },
          {
            "name": "follow_redirects",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Follow redirects",
              "default": true,
              "title": "Follow Redirects"
            },
            "description": "Follow redirects"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/url/parse": {
      "get": {
        "tags": [
          "URL Tools"
        ],
        "summary": "Parse and analyze a URL",
        "operationId": "parse_url_url_parse_get",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "URL to parse",
              "title": "Url"
            },
            "description": "URL to parse"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/url/bulk/status": {
      "post": {
        "tags": [
          "URL Tools"
        ],
        "summary": "Check status of multiple URLs (max 20)",
        "operationId": "bulk_status_url_bulk_status_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkStatusRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BulkStatusRequest": {
        "properties": {
          "urls": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Urls"
          }
        },
        "type": "object",
        "required": [
          "urls"
        ],
        "title": "BulkStatusRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "servers": [
    {
      "url": "https://niche-trend-api.onrender.com",
      "description": "Production"
    }
  ]
}