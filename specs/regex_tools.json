{
  "openapi": "3.1.0",
  "info": {
    "title": "Regex Tester and Tools",
    "description": "Test regular expressions against text, find all matches with positions, replace patterns, split text, and validate regex syntax. Includes a library of 12 common regex patterns for emails, URLs, phones, and more.",
    "version": "1.0.0"
  },
  "paths": {
    "/regex/": {
      "get": {
        "tags": [
          "Regex Tools"
        ],
        "summary": "API Info",
        "operationId": "regex_info_regex__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/regex/test": {
      "get": {
        "tags": [
          "Regex Tools"
        ],
        "summary": "Test a regex pattern against text",
        "operationId": "test_regex_regex_test_get",
        "parameters": [
          {
            "name": "pattern",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Regular expression pattern",
              "title": "Pattern"
            },
            "description": "Regular expression pattern"
          },
          {
            "name": "text",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Text to test against",
              "title": "Text"
            },
            "description": "Text to test against"
          },
          {
            "name": "flags",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Flags: i=ignorecase, m=multiline, s=dotall",
              "default": "",
              "title": "Flags"
            },
            "description": "Flags: i=ignorecase, m=multiline, s=dotall"
          },
          {
            "name": "max_matches",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "default": 100,
              "title": "Max Matches"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
