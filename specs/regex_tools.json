      "get": {
        "tags": [
          "Regex Tools"
        ],
        "summary": "Replace pattern matches in text",
        "operationId": "replace_regex_regex_replace_get",
        "parameters": [
          {
            "name": "pattern",
            "in": "query",
            "required": true,
            "schema": {
