        "summary": "API Info",
        "operationId": "sentiment_info_sentiment__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/sentiment/analyze": {
      "get": {
        "tags": [
          "Sentiment Analysis"
        ],
        "summary": "Analyze sentiment of a text",
        "operationId": "analyze_sentiment_sentiment_analyze_get",
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
