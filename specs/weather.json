{
  "openapi": "3.1.0",
  "info": {
    "title": "Weather and Forecast",
    "description": "Current weather, 16-day forecasts, and coordinate-based lookups for any city worldwide. Powered by Open-Meteo using ECMWF data. Includes temperature, humidity, wind, precipitation, and condition codes.",
    "version": "1.0.0"
  },
  "paths": {
    "/weather/": {
      "get": {
        "tags": [
          "Weather"
        ],
        "summary": "API Info",
        "operationId": "weather_info_weather__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/weather/current": {
      "get": {
        "tags": [
          "Weather"
        ],
        "summary": "Get current weather for a city",
        "operationId": "current_weather_weather_current_get",
        "parameters": [
          {
            "name": "city",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "City name (e.g. 'New York', 'London', 'Tokyo')",
              "title": "City"
            },
            "description": "City name (e.g. 'New York', 'London', 'Tokyo')"
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Temperature units: celsius or fahrenheit",
              "default": "celsius",
              "title": "Units"
            },
            "description": "Temperature units: celsius or fahrenheit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/weather/forecast": {
      "get": {
        "tags": [
          "Weather"
        ],
        "summary": "Get 7-day weather forecast",
        "operationId": "forecast_weather_forecast_get",
        "parameters": [
          {
            "name": "city",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "City name",
              "title": "City"
            },
            "description": "City name"
          },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 16,
              "minimum": 1,
              "description": "Number of forecast days (1-16)",
              "default": 7,
              "title": "Days"
            },
            "description": "Number of forecast days (1-16)"
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Temperature units: celsius or fahrenheit",
              "default": "celsius",
              "title": "Units"
            },
            "description": "Temperature units: celsius or fahrenheit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/weather/coordinates": {
      "get": {
        "tags": [
          "Weather"
        ],
        "summary": "Get weather by latitude and longitude",
        "operationId": "weather_by_coords_weather_coordinates_get",
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "description": "Latitude",
              "title": "Lat"
            },
            "description": "Latitude"
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "description": "Longitude",
              "title": "Lon"
            },
            "description": "Longitude"
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Temperature units: celsius or fahrenheit",
              "default": "celsius",
              "title": "Units"
            },
            "description": "Temperature units: celsius or fahrenheit"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "servers": [
    {
      "url": "https://niche-trend-api.onrender.com",
      "description": "Production"
    }
  ]
}