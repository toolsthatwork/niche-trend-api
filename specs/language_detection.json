{
  "openapi": "3.1.0",
  "info": {
    "title": "Language Detection",
    "description": "Detect the language of any text with confidence scores. Supports 55+ languages including English, French, Spanish, Chinese, Arabic, Japanese, and more. Bulk detection of up to 50 texts per request.",
    "version": "1.0.0"
  },
  "paths": {
    "/language/": {
      "get": {
        "tags": [
          "Language Detection"
        ],
        "summary": "API Info",
        "operationId": "language_info_language__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/language/detect": {
      "get": {
        "tags": [
          "Language Detection"
        ],
        "summary": "Detect the language of a text",
        "operationId": "detect_language_language_detect_get",
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Text to detect language for",
              "title": "Text"
            },
            "description": "Text to detect language for"
          },
          {
            "name": "probabilities",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Return language probabilities",
              "default": false,
              "title": "Probabilities"
            },
            "description": "Return language probabilities"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/language/detect/bulk": {
      "post": {
        "tags": [
          "Language Detection"
        ],
        "summary": "Detect language for multiple texts (max 50)",
        "operationId": "detect_bulk_language_detect_bulk_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchDetectRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/language/supported": {
      "get": {
        "tags": [
          "Language Detection"
        ],
        "summary": "List all supported languages",
        "operationId": "supported_languages_language_supported_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BatchDetectRequest": {
        "properties": {
          "texts": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Texts"
          }
        },
        "type": "object",
        "required": [
          "texts"
        ],
        "title": "BatchDetectRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "servers": [
    {
      "url": "https://niche-trend-api.onrender.com",
      "description": "Production"
    }
  ]
}