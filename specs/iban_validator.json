      "get": {
        "tags": [
          "IBAN Validator"
        ],
        "summary": "API Info",
        "operationId": "iban_info_iban__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/iban/validate": {
      "get": {
        "tags": [
          "IBAN Validator"
        ],
        "summary": "Validate an IBAN number",
        "operationId": "validate_iban_validate_get",
        "parameters": [
          {
            "name": "iban",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "IBAN to validate (spaces allowed)",
              "title": "Iban"
            },
            "description": "IBAN to validate (spaces allowed)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
