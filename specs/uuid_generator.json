        "summary": "Generate UUID v4 (random)",
        "operationId": "generate_v4_uuid_v4_get",
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Number of UUIDs to generate (1-100)",
              "default": 1,
