      "get": {
        "tags": [
          "UUID Generator"
        ],
        "summary": "Generate UUID v5 (name-based, SHA-1)",
        "operationId": "generate_v5_uuid_v5_get",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Name to hash into UUID",
              "title": "Name"
            },
            "description": "Name to hash into UUID"
          },
          {
            "name": "namespace",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Namespace: dns, url, oid, x500, or a custom UUID",
