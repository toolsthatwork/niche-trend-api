      "get": {
        "tags": [
          "UUID Generator"
        ],
        "summary": "Generate UUID v1 (time-based)",
        "operationId": "generate_v1_uuid_v1_get",
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "default": 1,
              "title": "Count"
