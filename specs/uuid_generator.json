      "get": {
        "tags": [
          "UUID Generator"
        ],
        "summary": "API Info",
        "operationId": "uuid_info_uuid__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/uuid/v4": {
      "get": {
