{
  "openapi": "3.1.0",
  "info": {
    "title": "Profanity Filter and Content Moderation",
    "description": "Detect and censor profanity in text. Returns whether text is clean, which words were flagged, and a censored version. Supports bulk moderation of up to 100 texts per request with custom censor characters.",
    "version": "1.0.0"
  },
  "paths": {
    "/profanity/": {
      "get": {
        "tags": [
          "Profanity Filter"
        ],
        "summary": "API Info",
        "operationId": "profanity_info_profanity__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/profanity/check": {
      "get": {
        "tags": [
          "Profanity Filter"
        ],
        "summary": "Check if text contains profanity",
        "operationId": "check_profanity_profanity_check_get",
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Text to check",
              "title": "Text"
            },
            "description": "Text to check"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/profanity/censor": {
      "get": {
        "tags": [
          "Profanity Filter"
        ],
        "summary": "Censor profanity in text",
        "operationId": "censor_text_profanity_censor_get",
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Text to censor",
              "title": "Text"
            },
            "description": "Text to censor"
          },
          {
            "name": "censor_char",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Character to replace profanity with (default: *)",
              "default": "*",
              "title": "Censor Char"
            },
            "description": "Character to replace profanity with (default: *)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/profanity/bulk": {
      "post": {
        "tags": [
          "Profanity Filter"
        ],
        "summary": "Check/censor multiple texts (max 100)",
        "operationId": "bulk_check_profanity_bulk_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BulkRequest": {
        "properties": {
          "texts": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Texts"
          },
          "censor_char": {
            "type": "string",
            "title": "Censor Char",
            "default": "*"
          }
        },
        "type": "object",
        "required": [
          "texts"
        ],
        "title": "BulkRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "servers": [
    {
      "url": "https://niche-trend-api.onrender.com",
      "description": "Production"
    }
  ]
}