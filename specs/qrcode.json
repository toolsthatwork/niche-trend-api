              "title": "Size"
            },
            "description": "QR code box size (1-40, default 10)"
          },
          {
            "name": "border",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 10,
              "minimum": 0,
              "description": "Border size in boxes (default 4)",
