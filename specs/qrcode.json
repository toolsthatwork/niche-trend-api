          "QR Code Generator"
        ],
        "summary": "Generate a QR code as PNG image",
        "operationId": "generate_qr_qrcode_generate_get",
        "parameters": [
          {
            "name": "data",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
