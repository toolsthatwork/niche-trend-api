              "title": "Data"
            },
            "description": "The data to encode (URL, text, email, phone, etc.)"
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 40,
              "minimum": 1,
              "description": "QR code box size (1-40, default 10)",
