            "description": "Foreground color (e.g. 'black', '#000000')"
          },
          {
            "name": "back_color",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Background color (e.g. 'white', '#ffffff')",
              "default": "white",
              "title": "Back Color"
            },
            "description": "Background color (e.g. 'white', '#ffffff')"
          },
          {
            "name": "style",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Module style: square, rounded, circle",
              "default": "square",
              "title": "Style"
            },
            "description": "Module style: square, rounded, circle"
