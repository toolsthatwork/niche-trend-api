            },
            "description": "Border size in boxes (default 4)"
          },
          {
            "name": "fill_color",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Foreground color (e.g. 'black', '#000000')",
              "default": "black",
              "title": "Fill Color"
