{
  "openapi": "3.1.0",
  "info": {
    "title": "SSL Certificate Checker",
    "description": "Check SSL certificate validity, expiry date, issuer, subject alternative names, and WCAG compliance for any domain. Bulk-check up to 20 domains at once. Returns days until expiry and expiration warnings.",
    "version": "1.0.0"
  },
  "paths": {
    "/ssl/": {
      "get": {
        "tags": [
          "SSL Certificate Checker"
        ],
        "summary": "API Info",
        "operationId": "ssl_info_ssl__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/ssl/check": {
      "get": {
        "tags": [
          "SSL Certificate Checker"
        ],
        "summary": "Check SSL certificate for a domain",
        "operationId": "ssl_check_ssl_check_get",
        "parameters": [
          {
            "name": "domain",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Domain to check (e.g. google.com or https://google.com)",
              "title": "Domain"
            },
            "description": "Domain to check (e.g. google.com or https://google.com)"
          },
          {
            "name": "port",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 65535,
              "minimum": 1,
              "description": "Port (default: 443)",
              "default": 443,
              "title": "Port"
            },
            "description": "Port (default: 443)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/ssl/expiry": {
      "get": {
        "tags": [
          "SSL Certificate Checker"
        ],
        "summary": "Quick check \u2014 days until SSL certificate expires",
        "operationId": "ssl_expiry_ssl_expiry_get",
        "parameters": [
          {
            "name": "domain",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Domain to check",
              "title": "Domain"
            },
            "description": "Domain to check"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/ssl/bulk": {
      "post": {
        "tags": [
          "SSL Certificate Checker"
        ],
        "summary": "Check SSL for multiple domains (max 20)",
        "operationId": "ssl_bulk_ssl_bulk_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BulkRequest": {
        "properties": {
          "domains": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Domains"
          },
          "port": {
            "type": "integer",
            "title": "Port",
            "default": 443
          }
        },
        "type": "object",
        "required": [
          "domains"
        ],
        "title": "BulkRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "servers": [
    {
      "url": "https://niche-trend-api.onrender.com",
      "description": "Production"
    }
  ]
}